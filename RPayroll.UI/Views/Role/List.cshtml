@{
    ViewData["Title"] = "Role Management";
}

<h2>Role Management</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5>Create Role</h5>
        <div class="form-wrapper">
            <div class="form-layout">
                <div class="form-info">
                    <div class="info-item">Provide a unique role name.</div>
                    <div class="info-item">Set the hierarchy level (lower is higher authority).</div>
                </div>
                <div class="form-fields">
                    <div class="form-group">
                        <label class="form-label">Role Name</label>
                        <input class="form-control" id="roleName" placeholder="Role name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Hierarchy Level</label>
                        <input class="form-control" id="roleLevel" type="number" placeholder="Hierarchy level" />
                    </div>
                </div>
            </div>
        </div>
        <button class="btn btn-primary" id="createRoleBtn">Create</button>
        <div class="mt-2" id="roleCreateResult"></div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover" id="roleTable">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Level</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="roleEditModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editRoleId" />
                <div class="mb-2">
                    <label class="form-label">Name</label>
                    <input class="form-control" id="editRoleName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Hierarchy Level</label>
                    <input class="form-control" id="editRoleLevel" type="number" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveRoleBtn">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let roleEditModal;

async function loadRoles() {
    const response = await fetch('/Role/GetAll');
    const data = response.ok ? await response.json() : [];
    const tbody = document.querySelector('#roleTable tbody');
    tbody.innerHTML = '';
    data.forEach(role => {
        const status = role.status === 200
            ? '<span class="badge bg-danger badge-status">Inactive</span>'
            : '<span class="badge bg-success badge-status">Active</span>';
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${role.id}</td>
            <td>${role.name}</td>
            <td>${role.hierarchyLevel}</td>
            <td>${status}</td>
            <td>
                <button class="btn btn-sm btn-outline-secondary" onclick="openRoleEdit(${role.id})"><i class="fa fa-pen"></i></button>
                <button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteRole(${role.id})"><i class="fa fa-trash"></i></button>
            </td>
        `;
        tbody.appendChild(row);
    });
}

window.openRoleEdit = async function(id) {
    const response = await fetch('/Role/GetAll');
    const roles = response.ok ? await response.json() : [];
    const role = roles.find(r => r.id === id);
    if (!role) return;

    document.getElementById('editRoleId').value = role.id;
    document.getElementById('editRoleName').value = role.name;
    document.getElementById('editRoleLevel').value = role.hierarchyLevel;

    roleEditModal.show();
}

window.deleteRole = async function(id) {
    const response = await fetch(`/Role/Delete/${id}`, { method: 'DELETE' });
    if (response.ok) {
        await loadRoles();
    }
}

document.getElementById('createRoleBtn').addEventListener('click', async () => {
    const payload = {
        name: document.getElementById('roleName').value,
        hierarchyLevel: parseInt(document.getElementById('roleLevel').value || '0')
    };

    const response = await fetch('/Role/Create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    const resultEl = document.getElementById('roleCreateResult');
    if (response.ok) {
        resultEl.innerHTML = '<div class="alert alert-success">Role created</div>';
        await loadRoles();
    } else {
        resultEl.innerHTML = '<div class="alert alert-danger">Create failed</div>';
    }
});

document.getElementById('saveRoleBtn').addEventListener('click', async () => {
    const id = document.getElementById('editRoleId').value;
    const payload = {
        id: parseInt(id),
        name: document.getElementById('editRoleName').value,
        hierarchyLevel: parseInt(document.getElementById('editRoleLevel').value || '0'),
        status: 30
    };

    const response = await fetch(`/Role/Update/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    if (response.ok) {
        roleEditModal.hide();
        await loadRoles();
    }
});

document.addEventListener('DOMContentLoaded', () => {
    roleEditModal = new bootstrap.Modal(document.getElementById('roleEditModal'));
    loadRoles();
});
</script>
}
