@{
    ViewData["Title"] = "Employee List";
}

<h2>Employees</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover" id="employeeTable">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Position</th>
                    <th>Manager</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Are you sure you want to delete this employee?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let deleteId = null;
let deleteModal;

async function loadEmployees() {
    const response = await fetch('/Employee/GetAll');
    const data = response.ok ? await response.json() : [];
    const tbody = document.querySelector('#employeeTable tbody');
    tbody.innerHTML = '';
    data.forEach(emp => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${emp.id}</td>
            <td>${emp.firstName} ${emp.lastName}</td>
            <td>${emp.department ?? ''}</td>
            <td>${emp.position ?? ''}</td>
            <td>${emp.managerId ?? ''}</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" href="/Employee/Details/${emp.id}">Details</a>
                <a class="btn btn-sm btn-outline-secondary ms-1" href="/Employee/Edit/${emp.id}"><i class="fa fa-pen"></i></a>
                <button class="btn btn-sm btn-outline-danger ms-1" onclick="openDelete(${emp.id})"><i class="fa fa-trash"></i></button>
            </td>
        `;
        tbody.appendChild(row);
    });
}

window.openDelete = function(id) {
    deleteId = id;
    deleteModal.show();
}

document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
    if (!deleteId) return;
    const response = await fetch(`/Employee/Delete/${deleteId}`, { method: 'DELETE' });
    if (response.ok) {
        deleteModal.hide();
        await loadEmployees();
    }
});

document.addEventListener('DOMContentLoaded', () => {
    deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
    loadEmployees();
});
</script>
}
