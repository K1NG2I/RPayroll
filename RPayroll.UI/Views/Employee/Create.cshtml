@inject RPayroll.UI.Services.TokenStore TokenStore
@{
    ViewData["Title"] = "Create Employee";
    var canManageLogin = string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase)
        || string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase);
    var isHr = string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase);
}

<h2>Create Employee</h2>

<div class="form-wrapper">
    <div class="form-layout">
        <div class="form-info">
            <div class="info-item">Enter the employee’s personal and job details.</div>
            <div class="info-item">Enable login creation if a user account is required.</div>
            <div class="info-item">Provide bank details for salary payouts.</div>
            <div class="info-item">Set leave allocations for the employee.</div>
            <div class="info-item">Add one or more contact persons.</div>
        </div>
        <div class="form-fields">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5>Basic Information</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">First Name</label>
                            <input class="form-control" id="firstName" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Last Name</label>
                            <input class="form-control" id="lastName" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Email</label>
                            <input class="form-control" id="email" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Phone</label>
                            <input class="form-control" id="phone" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Address</label>
                            <input class="form-control" id="address" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Date Of Joining</label>
                            <input class="form-control" id="dateOfJoining" type="date" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Department</label>
                            <input class="form-control" id="department" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Position</label>
                            <input class="form-control" id="position" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Basic Salary</label>
                            <input class="form-control" id="basicSalary" type="number" step="0.01" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Manager</label>
                            <select class="form-select" id="managerSelect"></select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5>Create Login</h5>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="createLogin" />
                        <label class="form-check-label">Create Login</label>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Username</label>
                            <input class="form-control login-field" id="username" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Password</label>
                            <input class="form-control login-field" id="password" type="password" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Role</label>
                            <select class="form-select login-field" id="roleSelect"></select>
                        </div>
                    </div>
                    @if (!canManageLogin)
                    {
                        <div class="text-muted">Only Admin or HR can create login details.</div>
                    }
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5>Bank Details</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Bank Name</label>
                            <input class="form-control" id="bankName" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Account Number</label>
                            <input class="form-control" id="bankAccountNumber" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">IFSC Code</label>
                            <input class="form-control" id="ifscCode" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5>Leave Allocation</h5>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Leave Type</th>
                                <th>Total Allowed</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Sick Leave</td>
                                <td><input class="form-control" type="number" id="totalSickLeaves" min="0" value="0" /></td>
                            </tr>
                            <tr>
                                <td>Casual Leave</td>
                                <td><input class="form-control" type="number" id="totalCasualLeaves" min="0" value="0" /></td>
                            </tr>
                            <tr>
                                <td>Government Leave</td>
                                <td><input class="form-control" type="number" id="totalGovernmentLeaves" min="0" value="0" /></td>
                            </tr>
                            <tr>
                                <td>Unpaid Leave</td>
                                <td><input class="form-control" type="number" id="totalUnpaidLeaves" min="0" value="0" /></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="mb-0">Contact Persons</h5>
                        <button class="btn btn-sm btn-primary" id="addContactBtn"><i class="fa fa-plus"></i> Add</button>
                    </div>
                    <table class="table table-hover" id="contactTable">
                        <thead>
                            <tr>
                                <th>Full Name</th>
                                <th>Relationship</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>Primary</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>

            <button class="btn btn-primary" id="createBtn">Create Employee</button>
            <div class="mt-3" id="createResult"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="contactModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contact Person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="contactId" />
                <div class="mb-2">
                    <label class="form-label">Full Name</label>
                    <input class="form-control" id="contactName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Relationship</label>
                    <input class="form-control" id="contactRelationship" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Phone</label>
                    <input class="form-control" id="contactPhone" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Email</label>
                    <input class="form-control" id="contactEmail" />
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="contactPrimary" />
                    <label class="form-check-label">Is Primary</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveContactBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="contactDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Delete this contact person?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmContactDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const canManageLogin = @canManageLogin.ToString().ToLower();
const isHr = @isHr.ToString().ToLower();

$('#managerSelect').select2({
    placeholder: 'Search manager',
    ajax: {
        url: '/Employee/Search',
        delay: 250,
        data: params => ({ query: params.term || '' }),
        processResults: data => ({
            results: data.map(item => ({ id: item.id, text: item.fullName }))
        })
    }
});

let contactModal;
let contactDeleteModal;
let deleteContactId = null;
const contacts = [];

function renderContacts() {
    const tbody = document.querySelector('#contactTable tbody');
    tbody.innerHTML = '';
    contacts.forEach(c => {
        const primaryBadge = c.isPrimary ? '<span class="badge bg-success badge-status">Yes</span>' : '';
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${c.name}</td>
            <td>${c.relationship ?? ''}</td>
            <td>${c.phone ?? ''}</td>
            <td>${c.email ?? ''}</td>
            <td>${primaryBadge}</td>
            <td>
                <button class="btn btn-sm btn-outline-secondary" onclick="editContact(${c.tempId})"><i class="fa fa-pen"></i></button>
                <button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteContact(${c.tempId})"><i class="fa fa-trash"></i></button>
            </td>
        `;
        tbody.appendChild(row);
    });
}

window.editContact = function(tempId) {
    const contact = contacts.find(c => c.tempId === tempId);
    if (!contact) return;

    document.getElementById('contactId').value = contact.tempId;
    document.getElementById('contactName').value = contact.name;
    document.getElementById('contactRelationship').value = contact.relationship ?? '';
    document.getElementById('contactPhone').value = contact.phone ?? '';
    document.getElementById('contactEmail').value = contact.email ?? '';
    document.getElementById('contactPrimary').checked = contact.isPrimary === true;
    contactModal.show();
}

window.deleteContact = function(tempId) {
    deleteContactId = tempId;
    contactDeleteModal.show();
}

document.getElementById('addContactBtn').addEventListener('click', () => {
    document.getElementById('contactId').value = '';
    document.getElementById('contactName').value = '';
    document.getElementById('contactRelationship').value = '';
    document.getElementById('contactPhone').value = '';
    document.getElementById('contactEmail').value = '';
    document.getElementById('contactPrimary').checked = false;
    contactModal.show();
});

document.getElementById('saveContactBtn').addEventListener('click', () => {
    const tempId = document.getElementById('contactId').value;
    const payload = {
        tempId: tempId ? parseInt(tempId) : Date.now(),
        name: document.getElementById('contactName').value,
        relationship: document.getElementById('contactRelationship').value,
        phone: document.getElementById('contactPhone').value,
        email: document.getElementById('contactEmail').value,
        isPrimary: document.getElementById('contactPrimary').checked
    };

    if (payload.isPrimary) {
        contacts.forEach(c => c.isPrimary = false);
    }

    const existingIndex = contacts.findIndex(c => c.tempId === payload.tempId);
    if (existingIndex >= 0) {
        contacts[existingIndex] = payload;
    } else {
        contacts.push(payload);
    }

    contactModal.hide();
    renderContacts();
});

document.getElementById('confirmContactDelete').addEventListener('click', () => {
    if (!deleteContactId) return;
    const index = contacts.findIndex(c => c.tempId === deleteContactId);
    if (index >= 0) {
        contacts.splice(index, 1);
    }
    contactDeleteModal.hide();
    renderContacts();
});

function toggleLoginFields(enabled) {
    document.querySelectorAll('.login-field').forEach(el => {
        el.disabled = !enabled;
    });
}

async function loadRoles() {
    const response = await fetch('/Role/GetAll');
    const data = response.ok ? await response.json() : [];
    const roleSelect = document.getElementById('roleSelect');
    roleSelect.innerHTML = '';
    data.forEach(role => {
        if (isHr && role.name.toLowerCase() === 'admin') {
            return;
        }
        const option = document.createElement('option');
        option.value = role.id;
        option.textContent = role.name;
        roleSelect.appendChild(option);
    });
    if (!canManageLogin) {
        roleSelect.disabled = true;
    }
}

document.getElementById('createLogin').addEventListener('change', (e) => {
    if (!canManageLogin) {
        e.target.checked = false;
        toggleLoginFields(false);
        return;
    }
    toggleLoginFields(e.target.checked);
});

const createBtn = document.getElementById('createBtn');
if (createBtn) {
    createBtn.addEventListener('click', async () => {
        const payload = {
            firstName: document.getElementById('firstName').value,
            lastName: document.getElementById('lastName').value,
            email: document.getElementById('email').value,
            phone: document.getElementById('phone').value,
            address: document.getElementById('address').value,
            dateOfJoining: document.getElementById('dateOfJoining').value,
            department: document.getElementById('department').value,
            position: document.getElementById('position').value,
            basicSalary: parseFloat(document.getElementById('basicSalary').value || '0'),
            managerId: $('#managerSelect').val() ? parseInt($('#managerSelect').val()) : null,
            createLogin: document.getElementById('createLogin').checked,
            username: document.getElementById('username').value,
            password: document.getElementById('password').value,
            roleName: document.getElementById('roleSelect').selectedOptions[0]?.text ?? 'Employee',
            bankName: document.getElementById('bankName').value,
            bankAccountNumber: document.getElementById('bankAccountNumber').value,
            ifscCode: document.getElementById('ifscCode').value,
            totalSickLeaves: parseInt(document.getElementById('totalSickLeaves').value || '0'),
            totalCasualLeaves: parseInt(document.getElementById('totalCasualLeaves').value || '0'),
            totalGovernmentLeaves: parseInt(document.getElementById('totalGovernmentLeaves').value || '0'),
            totalUnpaidLeaves: parseInt(document.getElementById('totalUnpaidLeaves').value || '0'),
            contactPersons: contacts.map(c => ({
                name: c.name,
                relationship: c.relationship,
                phone: c.phone,
                email: c.email,
                isPrimary: c.isPrimary
            }))
        };

        const response = await fetch('/Employee/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const resultEl = document.getElementById('createResult');
        if (response.ok) {
            const data = await response.json();
            resultEl.innerHTML = `<div class="alert alert-success">Created employee #${data.id}</div>`;
        } else {
            resultEl.innerHTML = '<div class="alert alert-danger">Create failed</div>';
        }
    });
}

document.addEventListener('DOMContentLoaded', () => {
    contactModal = new bootstrap.Modal(document.getElementById('contactModal'));
    contactDeleteModal = new bootstrap.Modal(document.getElementById('contactDeleteModal'));
    renderContacts();
    toggleLoginFields(false);
    loadRoles();
    if (!canManageLogin) {
        document.getElementById('createLogin').disabled = true;
    }
});
</script>
}
