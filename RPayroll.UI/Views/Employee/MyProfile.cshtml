@{
    ViewData["Title"] = "My Profile";
}

<h2>My Profile</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5>Basic Information</h5>
        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="form-label">Email</label>
                <input class="form-control" id="profileEmail" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Phone</label>
                <input class="form-control" id="profilePhone" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Address</label>
                <input class="form-control" id="profileAddress" />
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5>Bank Details</h5>
        <div class="row">
            <div class="col-md-4 mb-2">
                <label class="form-label">Bank Name</label>
                <input class="form-control" id="profileBankName" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">Account Number</label>
                <input class="form-control" id="profileBankAccount" />
            </div>
            <div class="col-md-4 mb-2">
                <label class="form-label">IFSC Code</label>
                <input class="form-control" id="profileIFSC" />
            </div>
        </div>
        <button class="btn btn-primary" id="saveProfileBtn">Save</button>
        <div class="mt-2" id="profileResult"></div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0">Contact Persons</h5>
            <button class="btn btn-sm btn-primary" id="addContactBtn"><i class="fa fa-plus"></i> Add</button>
        </div>
        <table class="table table-hover" id="contactTable">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Relationship</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Primary</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="contactModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Contact Person</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="contactId" />
                <div class="mb-2">
                    <label class="form-label">Full Name</label>
                    <input class="form-control" id="contactName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Relationship</label>
                    <input class="form-control" id="contactRelationship" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Phone</label>
                    <input class="form-control" id="contactPhone" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Email</label>
                    <input class="form-control" id="contactEmail" />
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="contactPrimary" />
                    <label class="form-check-label">Is Primary</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveContactBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="contactDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Delete this contact person?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmContactDelete">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let employeeId = null;
let contactModal;
let contactDeleteModal;
let deleteContactId = null;

async function loadProfile() {
    const response = await fetch('/Employee/GetMyProfile');
    const data = response.ok ? await response.json() : null;
    if (!data) return;

    employeeId = data.id;
    document.getElementById('profileEmail').value = data.email ?? '';
    document.getElementById('profilePhone').value = data.phone ?? '';
    document.getElementById('profileAddress').value = data.address ?? '';
    document.getElementById('profileBankName').value = data.bankName ?? '';
    document.getElementById('profileBankAccount').value = data.bankAccountNumber ?? '';
    document.getElementById('profileIFSC').value = data.ifscCode ?? '';

    renderContacts(data.contactPersons || []);
}

function renderContacts(contacts) {
    const tbody = document.querySelector('#contactTable tbody');
    tbody.innerHTML = '';
    contacts.forEach(c => {
        const primaryBadge = c.isPrimary ? '<span class="badge bg-success badge-status">Yes</span>' : '';
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${c.name}</td>
            <td>${c.relationship ?? ''}</td>
            <td>${c.phone ?? ''}</td>
            <td>${c.email ?? ''}</td>
            <td>${primaryBadge}</td>
            <td>
                <button class="btn btn-sm btn-outline-secondary" onclick="editContact(${c.id})"><i class="fa fa-pen"></i></button>
                <button class="btn btn-sm btn-outline-danger ms-1" onclick="deleteContact(${c.id})"><i class="fa fa-trash"></i></button>
            </td>
        `;
        tbody.appendChild(row);
    });
}

window.editContact = async function(contactId) {
    const response = await fetch('/Employee/GetMyProfile');
    const data = response.ok ? await response.json() : null;
    if (!data) return;

    const contact = (data.contactPersons || []).find(c => c.id === contactId);
    if (!contact) return;

    document.getElementById('contactId').value = contact.id;
    document.getElementById('contactName').value = contact.name;
    document.getElementById('contactRelationship').value = contact.relationship ?? '';
    document.getElementById('contactPhone').value = contact.phone ?? '';
    document.getElementById('contactEmail').value = contact.email ?? '';
    document.getElementById('contactPrimary').checked = contact.isPrimary === true;
    contactModal.show();
}

window.deleteContact = function(contactId) {
    deleteContactId = contactId;
    contactDeleteModal.show();
}

document.getElementById('addContactBtn').addEventListener('click', () => {
    document.getElementById('contactId').value = '';
    document.getElementById('contactName').value = '';
    document.getElementById('contactRelationship').value = '';
    document.getElementById('contactPhone').value = '';
    document.getElementById('contactEmail').value = '';
    document.getElementById('contactPrimary').checked = false;
    contactModal.show();
});

document.getElementById('saveContactBtn').addEventListener('click', async () => {
    const contactId = document.getElementById('contactId').value;
    const payload = {
        employeeId: employeeId,
        name: document.getElementById('contactName').value,
        relationship: document.getElementById('contactRelationship').value,
        phone: document.getElementById('contactPhone').value,
        email: document.getElementById('contactEmail').value,
        isPrimary: document.getElementById('contactPrimary').checked
    };

    let response;
    if (contactId) {
        response = await fetch(`/Employee/UpdateContact?id=${employeeId}&contactId=${contactId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
    } else {
        response = await fetch(`/Employee/AddContact/${employeeId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
    }

    if (response.ok) {
        contactModal.hide();
        await loadProfile();
    }
});

document.getElementById('confirmContactDelete').addEventListener('click', async () => {
    if (!deleteContactId) return;
    const response = await fetch(`/Employee/RemoveContact?id=${employeeId}&contactId=${deleteContactId}`, { method: 'DELETE' });
    if (response.ok) {
        contactDeleteModal.hide();
        await loadProfile();
    }
});

document.getElementById('saveProfileBtn').addEventListener('click', async () => {
    const payload = {
        email: document.getElementById('profileEmail').value,
        phone: document.getElementById('profilePhone').value,
        address: document.getElementById('profileAddress').value,
        bankName: document.getElementById('profileBankName').value,
        bankAccountNumber: document.getElementById('profileBankAccount').value,
        ifscCode: document.getElementById('profileIFSC').value
    };

    const response = await fetch('/Employee/UpdateMyProfile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    const resultEl = document.getElementById('profileResult');
    if (response.ok) {
        resultEl.innerHTML = '<div class="alert alert-success">Profile updated</div>';
        await loadProfile();
    } else {
        resultEl.innerHTML = '<div class="alert alert-danger">Update failed</div>';
    }
});

document.addEventListener('DOMContentLoaded', () => {
    contactModal = new bootstrap.Modal(document.getElementById('contactModal'));
    contactDeleteModal = new bootstrap.Modal(document.getElementById('contactDeleteModal'));
    loadProfile();
});
</script>
}
