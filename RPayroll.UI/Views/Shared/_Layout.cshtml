@inject RPayroll.UI.Services.TokenStore TokenStore
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RPayroll</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RPayroll.UI.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">RPayroll</a>
            <div class="d-flex text-white">
                <span class="me-3">@TokenStore.Username</span>
                <span class="badge bg-secondary">@TokenStore.Role</span>
            </div>
        </div>
    </nav>

    <div class="d-flex">
        <div class="bg-light border-end" style="min-width: 230px;">
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action" asp-controller="Home" asp-action="Index">Dashboard</a>

                @if (!string.IsNullOrWhiteSpace(TokenStore.Role))
                {
                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "Manager", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Employee" asp-action="List">Employees</a>
                        <a class="list-group-item list-group-item-action" asp-controller="Employee" asp-action="Create">Create Employee</a>
                    }

                    <a class="list-group-item list-group-item-action" asp-controller="Leave" asp-action="Apply">Apply Leave</a>

                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "Manager", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Leave" asp-action="Approval">Leave Approval</a>
                    }

                    <a class="list-group-item list-group-item-action" asp-controller="Payroll" asp-action="Generate">Generate Payroll</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Payroll" asp-action="List">Payrolls</a>

                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="User" asp-action="List">User Management</a>
                    }
                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Role" asp-action="List">Role Management</a>
                    }
                }
                else
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Auth" asp-action="Login">Login</a>
                }
            </div>
        </div>

        <div class="container-fluid p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
