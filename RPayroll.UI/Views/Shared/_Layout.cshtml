@inject RPayroll.UI.Services.TokenStore TokenStore
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RPayroll</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RPayroll.UI.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">RPayroll</a>
                <div class="d-flex align-items-center text-white">
                    <span class="me-3">@TokenStore.Username</span>
                    <span class="badge bg-secondary me-3">@TokenStore.Role</span>
                    @if (!string.IsNullOrWhiteSpace(TokenStore.Token))
                    {
                        <form method="post" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="layout">
        <aside class="sidebar">
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action" asp-controller="Home" asp-action="Index">Dashboard</a>

                @if (!string.IsNullOrWhiteSpace(TokenStore.Role))
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Employee" asp-action="MyProfile">My Profile</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Attendance" asp-action="My">Attendance</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Leave" asp-action="Apply">Apply Leave</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Leave" asp-action="MyLeaves">Leave</a>
                    <a class="list-group-item list-group-item-action" asp-controller="Payroll" asp-action="List">Payroll</a>

                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "Manager", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Employee" asp-action="List">Employees</a>
                        <a class="list-group-item list-group-item-action" asp-controller="Employee" asp-action="Create">Create Employee</a>
                    }

                    if (string.Equals(TokenStore.Role, "Admin", StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(TokenStore.Role, "HR", StringComparison.OrdinalIgnoreCase))
                    {
                        <a class="list-group-item list-group-item-action" asp-controller="Attendance" asp-action="Marking">Attendance Marking</a>
                        <a class="list-group-item list-group-item-action" asp-controller="Attendance" asp-action="List">Attendance List</a>
                        <a class="list-group-item list-group-item-action" asp-controller="Leave" asp-action="Approval">Leave Approval</a>
                        <a class="list-group-item list-group-item-action" asp-controller="Role" asp-action="List">Role Management</a>
                    }
                }
                else
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Auth" asp-action="Login">Login</a>
                }
            </div>
        </aside>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
