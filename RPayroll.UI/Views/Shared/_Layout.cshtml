@inject RPayroll.UI.Services.TokenStore TokenStore
@inject RPayroll.UI.Services.MenuService MenuService
@using RPayroll.UI.Models
@{
    var menuItems = MenuService.GetMenuItems(TokenStore.Role);
    var topMenus = menuItems.Where(item => item.ParentId == null).ToList();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var activeTop = topMenus.FirstOrDefault(menu =>
        string.Equals(menu.Controller, currentController, StringComparison.OrdinalIgnoreCase) ||
        menu.Children.Any(child => string.Equals(child.Controller, currentController, StringComparison.OrdinalIgnoreCase)))
        ?? topMenus.FirstOrDefault();
    var sidebarItems = activeTop?.Children ?? new List<MenuItem>();

    string MenuUrl(MenuItem item)
    {
        if (!string.IsNullOrWhiteSpace(item.Controller) && !string.IsNullOrWhiteSpace(item.Action))
        {
            return Url.Action(item.Action, item.Controller) ?? "#";
        }

        var firstChild = item.Children.FirstOrDefault();
        if (firstChild != null)
        {
            return Url.Action(firstChild.Action, firstChild.Controller) ?? "#";
        }

        return "#";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RPayroll</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RPayroll.UI.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">RPayroll</a>
                @if (!string.IsNullOrWhiteSpace(TokenStore.Role))
                {
                    <ul class="navbar-nav me-auto">
                        @foreach (var menu in topMenus)
                        {
                            var isActive = activeTop != null && activeTop.Id == menu.Id;
                            <li class="nav-item">
                                <a class="nav-link @(isActive ? "active" : "")" href="@MenuUrl(menu)">@menu.Title</a>
                            </li>
                        }
                    </ul>
                }
                <div class="d-flex align-items-center text-white">
                    <span class="me-3">@TokenStore.Username</span>
                    <span class="badge bg-secondary me-3">@TokenStore.Role</span>
                    @if (!string.IsNullOrWhiteSpace(TokenStore.Token))
                    {
                        <form method="post" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="layout">
        <aside class="sidebar">
            <div class="list-group list-group-flush">
                @if (!string.IsNullOrWhiteSpace(TokenStore.Role))
                {
                    @foreach (var item in sidebarItems)
                    {
                        var isActive = string.Equals(item.Controller, currentController, StringComparison.OrdinalIgnoreCase)
                                       && string.Equals(item.Action, currentAction, StringComparison.OrdinalIgnoreCase);
                        <a class="list-group-item list-group-item-action @(isActive ? "active" : "")" href="@MenuUrl(item)">@item.Title</a>
                    }
                }
                else
                {
                    <a class="list-group-item list-group-item-action" asp-controller="Auth" asp-action="Login">Login</a>
                }
            </div>
        </aside>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
