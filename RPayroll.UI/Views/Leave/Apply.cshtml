@inject RPayroll.UI.Services.TokenStore TokenStore
@{
    ViewData["Title"] = "Apply Leave";
    var isEmployee = string.Equals(TokenStore.Role, "Employee", StringComparison.OrdinalIgnoreCase);
}

<h2>Apply Leave</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="form-wrapper">
            <div class="form-layout">
                <div class="form-info">
                    <div class="info-item">Select the employee applying for leave.</div>
                    <div class="info-item">Provide the leave start date.</div>
                    <div class="info-item">Provide the leave end date.</div>
                    <div class="info-item">Specify the leave type.</div>
                    <div class="info-item">Add a brief reason for the leave.</div>
                </div>
                <div class="form-fields">
                    @if (isEmployee)
                    {
                        <div class="form-group">
                            <label class="form-label">Employee</label>
                            <div class="form-control-plaintext" id="employeeLabel">Employee:</div>
                        </div>
                    }
                    else
                    {
                        <div class="form-group">
                            <label class="form-label">Employee</label>
                            <select class="form-select" id="employeeSelect"></select>
                        </div>
                    }
                    <div class="form-group">
                        <label class="form-label">Start Date</label>
                        <input class="form-control" id="startDate" type="date" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">End Date</label>
                        <input class="form-control" id="endDate" type="date" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Leave Type</label>
                        <input class="form-control" id="leaveType" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Reason</label>
                        <input class="form-control" id="reason" />
                    </div>
                    <button class="btn btn-primary" id="applyBtn">Apply</button>
                    <div class="mt-3" id="applyResult"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentEmployeeId = null;

@if (!isEmployee)
{
<text>
$('#employeeSelect').select2({
    placeholder: 'Search employee',
    ajax: {
        url: '/Employee/Search',
        delay: 250,
        data: params => ({ query: params.term || '' }),
        processResults: data => ({
            results: data.map(item => ({ id: item.id, text: item.fullName }))
        })
    }
});
</text>
}

async function loadEmployeeProfile() {
    const response = await fetch('/Employee/GetMyProfile');
    const profile = response.ok ? await response.json() : null;
    if (!profile) return;
    currentEmployeeId = profile.id;
    const label = document.getElementById('employeeLabel');
    if (label) {
        label.textContent = `Employee: ${profile.firstName} ${profile.lastName}`;
    }
}

document.getElementById('applyBtn').addEventListener('click', async () => {
    const payload = {
        employeeId: @isEmployee.ToString().ToLower() ? (currentEmployeeId ?? 0) : ($('#employeeSelect').val() ? parseInt($('#employeeSelect').val()) : 0),
        startDate: document.getElementById('startDate').value,
        endDate: document.getElementById('endDate').value,
        leaveType: document.getElementById('leaveType').value,
        reason: document.getElementById('reason').value
    };

    const response = await fetch('/Leave/Apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });

    const resultEl = document.getElementById('applyResult');
    if (response.ok) {
        const data = await response.json();
        resultEl.innerHTML = `<div class="alert alert-success">Leave applied (#${data.id})</div>`;
    } else {
        resultEl.innerHTML = '<div class="alert alert-danger">Leave apply failed</div>';
    }
});

@if (isEmployee)
{
<text>
loadEmployeeProfile();
</text>
}
</script>
}
