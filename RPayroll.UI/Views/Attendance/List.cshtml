@{
    ViewData["Title"] = "Attendance List";
}

<h2>Attendance List</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-3 mb-2">
                <label class="form-label">Employee</label>
                <select class="form-select" id="employeeSelect"></select>
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Month</label>
                <input class="form-control" id="monthInput" type="number" min="1" max="12" />
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Year</label>
                <input class="form-control" id="yearInput" type="number" min="2000" max="2100" />
            </div>
            <div class="col-md-2 mb-2 d-flex align-items-end">
                <button class="btn btn-outline-primary" id="loadBtn">Load</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover" id="attendanceTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const statusBadge = status => {
    switch (status) {
        case 0: return '<span class="badge bg-success badge-status">Present</span>';
        case 1: return '<span class="badge bg-danger badge-status">Absent</span>';
        case 2: return '<span class="badge bg-warning badge-status">HalfDay</span>';
        case 3: return '<span class="badge bg-primary badge-status">Leave</span>';
        case 4: return '<span class="badge bg-secondary badge-status">Holiday</span>';
        default: return '';
    }
};

$('#employeeSelect').select2({
    placeholder: 'Search employee',
    ajax: {
        url: '/Employee/Search',
        delay: 250,
        data: params => ({ query: params.term || '' }),
        processResults: data => ({
            results: data.map(item => ({ id: item.id, text: item.fullName }))
        })
    }
});

async function loadAttendance() {
    const employeeId = $('#employeeSelect').val();
    const month = document.getElementById('monthInput').value;
    const year = document.getElementById('yearInput').value;
    if (!employeeId || !month || !year) return;

    const response = await fetch(`/Attendance/GetByMonth?employeeId=${employeeId}&month=${month}&year=${year}`);
    const data = response.ok ? await response.json() : [];
    const tbody = document.querySelector('#attendanceTable tbody');
    tbody.innerHTML = '';
    data.forEach(item => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${item.date}</td>
            <td>${item.checkInTime ?? ''}</td>
            <td>${item.checkOutTime ?? ''}</td>
            <td>${statusBadge(item.status)}</td>
        `;
        tbody.appendChild(row);
    });
}

document.getElementById('loadBtn').addEventListener('click', loadAttendance);
</script>
}
