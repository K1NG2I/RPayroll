@{
    ViewData["Title"] = "My Attendance";
}

<h2>My Attendance</h2>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row">
            <div class="col-md-2 mb-2">
                <label class="form-label">Month</label>
                <input class="form-control" id="monthInput" type="number" min="1" max="12" />
            </div>
            <div class="col-md-2 mb-2">
                <label class="form-label">Year</label>
                <input class="form-control" id="yearInput" type="number" min="2000" max="2100" />
            </div>
            <div class="col-md-2 mb-2 d-flex align-items-end">
                <button class="btn btn-outline-primary" id="loadBtn">Load</button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover" id="attendanceTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const statusBadge = status => {
    switch (status) {
        case 0: return '<span class="badge bg-success badge-status">Present</span>';
        case 1: return '<span class="badge bg-danger badge-status">Absent</span>';
        case 2: return '<span class="badge bg-warning badge-status">HalfDay</span>';
        case 3: return '<span class="badge bg-primary badge-status">Leave</span>';
        case 4: return '<span class="badge bg-secondary badge-status">Holiday</span>';
        default: return '';
    }
};

async function loadAttendance() {
    const month = document.getElementById('monthInput').value;
    const year = document.getElementById('yearInput').value;

    let response;
    if (month && year) {
        const profile = await fetch('/Attendance/GetMyProfile');
        const profileData = profile.ok ? await profile.json() : null;
        if (!profileData) return;
        response = await fetch(`/Attendance/GetByMonth?employeeId=${profileData.id}&month=${month}&year=${year}`);
    } else {
        response = await fetch('/Attendance/GetMy');
    }

    const data = response && response.ok ? await response.json() : [];
    const tbody = document.querySelector('#attendanceTable tbody');
    tbody.innerHTML = '';
    data.forEach(item => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td>${item.date}</td>
            <td>${item.checkInTime ?? ''}</td>
            <td>${item.checkOutTime ?? ''}</td>
            <td>${statusBadge(item.status)}</td>
        `;
        tbody.appendChild(row);
    });
}

document.getElementById('loadBtn').addEventListener('click', loadAttendance);

loadAttendance();
</script>
}
